# Telegram API credentials (https://my.telegram.org)
API_ID=0
API_HASH=
BOT_TOKEN=

# Bot admin Telegram user ID
ADMIN_ID=0

# Space or comma separated channel/chat IDs the bot may process
ALLOWED_CHATS=

# MongoDB connection string (defaults to the compose service)
MONGO_URI=mongodb://mongo:27017

# Optional
LOG_LEVEL=INFO
PORT=8080
